# Backend API Configuration - REQUIRED
VITE_API_BASE_URL=http://localhost:8081

# Application Environment - can be 'development', 'staging', or 'production'
VITE_APP_ENV=development

# API Endpoints (Optional - if you want granular endpoint configuration)
VITE_API_AUTH_ENDPOINT=/api/auth
VITE_API_ADMIN_ENDPOINT=/api/admin
VITE_API_USER_ENDPOINT=/api/user
